{
  "name": "mcp-sumologic",
  "version": "2.0.0",
  "description": "Multi-region Sumo Logic MCP server for log analysis and issue detection",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts",
    "test": "jest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.11.0",
    "axios": "^1.6.0",
    "dotenv": "^16.3.1",
    "express": "^5.2.1",
    "moment": "^2.30.1",
    "query-string": "^9.3.1",
    "ramda": "^0.32.0",
    "request": "^2.88.2",
    "request-promise-native": "^1.0.9",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^20.10.0",
    "@types/ramda": "^0.31.1",
    "@types/request": "^2.48.13",
    "@types/request-promise-native": "^1.0.21",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.0",
    "tsx": "^4.6.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
