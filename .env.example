NODE_ENV=development
ENDPOINT=https://api.au.sumologic.com/api/v1
SUMO_API_ID=your_api_id_here
SUMO_API_KEY=your_api_key_here

# Slack Bot
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_APP_TOKEN=xapp-your-app-level-token
SLACK_PORT=3001

# Open WebUI (Falcon AI)
OPENWEBUI_URL=https://falconai.planview-dev.io
OPENWEBUI_API_KEY=your-openwebui-api-key
OPENWEBUI_MODEL=your-model-id
AI_MAX_TOKENS=4096

# MCP Tool IDs — set after registering MCP Sumo Logic server in Falcon AI
# Find the tool ID in Falcon AI: Admin → Tools → your MCP server's ID
# For MCP servers, usually: server:mcp:<server-id>
# Comma-separated if multiple
OPENWEBUI_TOOL_IDS=server:mcp:chitti